<script>
let recognition = null;
let isRecording = false;
let finalTranscript = '';

const contacts = [{ name: 'Momo', phone: '' }];
let selectedContact = contacts[0];

// Init speech recognition
function initRecognition() {
  const SRE = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SRE) {
    document.getElementById('noSupport').style.display = 'block';
    document.getElementById('micBtn').disabled = true;
    return false;
  }
  recognition = new SRE();
  recognition.lang = 'fr-FR';
  recognition.interimResults = true;
  recognition.continuous = true;

  recognition.onresult = (e) => {
    let interim = '';
    for (let i = e.resultIndex; i < e.results.length; i++) {
      if (e.results[i].isFinal) finalTranscript += e.results[i][0].transcript;
      else interim += e.results[i][0].transcript;
    }
    document.getElementById('transcriptContent').textContent = finalTranscript + interim;
    updateSendBtn();
    document.getElementById('transcriptBox').classList.toggle('has-text', !!(finalTranscript + interim));
  };

  recognition.onerror = (e) => {
    setStatus('Erreur micro : ' + e.error, 'error');
    stopRecording();
  };

  recognition.onend = () => { if (isRecording) recognition.start(); };
  return true;
}

function toggleRecord() {
  if (!recognition && !initRecognition()) return;
  isRecording ? stopRecording() : startRecording();
}

function startRecording() {
  finalTranscript = '';
  isRecording = true;
  recognition.start();
  document.getElementById('micBtn').classList.add('recording');
  document.getElementById('waveform').classList.add('active');
  document.getElementById('recordHint').textContent = 'Parle maintenant… Rappuie pour arrêter';
  setStatus('Enregistrement en cours…', 'active');
}

function stopRecording() {
  isRecording = false;
  recognition.stop();
  document.getElementById('micBtn').classList.remove('recording');
  document.getElementById('waveform').classList.remove('active');
  document.getElementById('recordHint').textContent = 'Appuie pour dicter ton message';
  const text = document.getElementById('transcriptContent').textContent.trim();
  setStatus(text ? 'Message prêt ✓' : 'En attente', text ? 'active' : '');
  updateSendBtn();
}

function updateSendBtn() {
  const text = document.getElementById('transcriptContent').textContent.trim();
  document.getElementById('sendBtn').disabled = !text;
}

function setStatus(msg, type) {
  document.getElementById('statusText').textContent = msg;
  const dot = document.getElementById('statusDot');
  dot.className = 'status-dot' + (type ? ' ' + type : '');
}

function sendSMS() {
  const text = document.getElementById('transcriptContent').textContent.trim();
  if (!text) return;
  const phone = selectedContact.phone || '';
  const uri = `sms:${phone}${phone ? '?' : ''}body=${encodeURIComponent(text)}`;
  window.location.href = uri;
}

// Contacts
function selectContact(el) {
  document.querySelectorAll('.contact-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  const name = el.dataset.name;
  selectedContact = contacts.find(c => c.name === name) || contacts[0];
}

function showAddContact() {
  document.getElementById('phoneInput').classList.add('visible');
}

function hideAddContact() {
  document.getElementById('phoneInput').classList.remove('visible');
  document.getElementById('contactName').value = '';
  document.getElementById('contactPhone').value = '';
}

function addContact() {
  const name = document.getElementById('contactName').value.trim();
  const phone = document.getElementById('contactPhone').value.trim();
  if (!name) { alert('Entre un prénom.'); return; }

  const contact = { name, phone };
  contacts.push(contact);

  const row = document.getElementById('contactRow');
  const addBtn = row.querySelector('.add-contact');
  const chip = document.createElement('div');
  chip.className = 'contact-chip';
  chip.dataset.name = name;
  chip.dataset.phone = phone;
  chip.innerHTML = `<div class="avatar">${name[0].toUpperCase()}</div>${name}`;
  chip.onclick = function() { selectContact(this); };
  row.insertBefore(chip, addBtn);

  hideAddContact();
  selectContact(chip);
}

// Listen for manual edits in transcript
document.getElementById('transcriptContent').addEventListener('input', updateSendBtn);
</script>

